# Pingtym Insights Configuration Template
# Copy this to .env and fill in the values

# Secret for signing session cookies (use a random 32-character string)
# Command: openssl rand -hex 32
SESSION_SECRET="your-random-session-secret-here"

# Secret for authorizing the /api/cron endpoint
CRON_SECRET="your-random-cron-secret-here"

# Turso Database Configuration (Optional - Falls back to local SQLite if empty)
# Use the URL and Auth Token provided by the Turso CLI or Dashboard
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# Environment (development or production)
ENV=development

# Server Port
PORT=8080
